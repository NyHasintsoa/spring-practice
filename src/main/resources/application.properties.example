###############################################
# Project Properties
###############################################
spring.application.name=Spring Api Ressource
server.port=8000
project.api.prefix=/api
project.login.max.attempts=3
project.frontend.url=https://127.0.0.1:3000
project.backend.url=https://127.0.0.1:8000
project.secret.key=abd2e2d1d4e90cd99695283c512f756b
spring.thymeleaf.check-template-location=false
spring.thymeleaf.suffix=.html
spring.profiles.active=local
###############################################
server.ssl.enabled=true
server.ssl.certificate=classpath:certs/localhost+2.pem
server.ssl.certificate-private-key=classpath:certs/localhost+2-key.pem
###############################################

###############################################
# Cybersource Properties
###############################################
project.cybersource.merchant.id=
project.cybersource.api.endpoint=https://apitest.cybersource.com
project.cybersource.checkout.url=https://testsecureacceptance.cybersource.com
project.cybersource.run.environment=apitest.cybersource.com
project.cybersource.request.timeout=30000
###############################################
project.cybersource.api.key.id=
project.cybersource.secret.key=
project.cybersource.access.key=
project.cybersource.profile.id=
###############################################
project.cybersource.certificate.file.name=
project.cybersource.certificate.password=
###############################################

###############################################
# SpringDoc Properties
###############################################
springdoc.api-docs.enabled=true
springdoc.api-docs.path=/api
springdoc.swagger-ui.path=/swagger-ui
springdoc.show-actuator=true
springdoc.cache.disabled=true
springdoc.swagger-ui.with-credentials=true
###############################################

###############################################
# Database Properties
###############################################
spring.datasource.url=jdbc:mysql://127.0.0.1:3306/database_name
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=username
spring.datasource.password=password
###############################################

###############################################
# Redis Database Properties
###############################################
spring.data.redis.host=127.0.0.1
spring.data.redis.port=6379
spring.data.redis.database=0
spring.data.redis.jedis.pool.max-active=8
spring.data.redis.jedis.pool.max-wait=-1ms
spring.data.redis.jedis.pool.max-idle=8
spring.data.redis.jedis.pool.min-idle=0
spring.session.redis.repository-type=default
###############################################

###############################################
# ORM Properties (JPA)
###############################################
#spring.jpa.properties.hibernate.default_schema=preferedSchema
#spring.jpa.properties.hibernate.transaction.jta.platform=""
#spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.database=mysql
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=true
###############################################

###############################################
# Mailing Properties
###############################################
project.mail.from=noreply@domain.com
project.name.from=Spring Admin Society
spring.mail.host=127.0.0.1
spring.mail.port=1143
spring.mail.ssl.enabled=true
spring.mail.protocol=smtps
spring.mail.username=admin@domain.com
spring.mail.password=Admin@123
spring.mail.test-connection=true
###############################################
spring.mail.properties[mail.smtps.auth]=true
spring.mail.properties[mail.smtps.starttls.enable]=true
spring.mail.properties[mail.smtps.starttls.required]=true
spring.mail.properties[mail.smtps.timeout]=3000
spring.mail.properties[mail.smtps.writetimeout]=5000
spring.mail.properties[mail.smtps.connectiontimeout]=5000
# STARTTLS Configuration ######################
# spring.mail.properties[mail.smtps.ssl.trust.store]=classpath:certs/mailpit.p12
# spring.mail.properties[mail.smtps.ssl.trust.store.password]=hasintsoa
# spring.mail.properties[mail.smtps.ssl.trust.store.type]=PKCS12
spring.mail.properties[mail.smtps.ssl.trust]=*
spring.mail.properties[mail.smtps.ssl.checkserveridentity]=false
###############################################
spring.mail.properties[mail.debug]=false
###############################################

###############################################
# Security Properties
###############################################
project.jwt.bearer.prefix=Bearer 
project.jwt.cookie.storage.key=project-jwt-token
project.jwt.token.expiration=3600000
project.jwt.refresh.token.expiration=604800000
###############################################
project.reset.password.selector.length=20
project.reset.password.token.expiration=3600
project.reset.password.cooldown=300
###############################################