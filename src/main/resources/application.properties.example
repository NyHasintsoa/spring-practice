###############################################
# Database Properties
###############################################
spring.application.name=Spring Api Ressource
project.api.prefix=/api
server.port=8000
project.entity.id.length=16
spring.thymeleaf.check-template-location=false
###############################################

###############################################
# Database Properties
###############################################
spring.datasource.url=jdbc:mysql://127.0.0.1:3306/spring_project
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.username=root
spring.datasource.password=hasintsoa
###############################################

###############################################
# ORM Properties (JPA)
###############################################
#spring.jpa.properties.hibernate.default_schema=preferedSchema
#spring.jpa.properties.hibernate.transaction.jta.platform=""
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.database=mysql
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
###############################################

###############################################
# Mailing Properties
###############################################
project.mail.from=noreply@domain.com
project.name.from=Spring Admin Society
spring.mail.host=127.0.0.1
spring.mail.port=1025
spring.mail.username=user
spring.mail.password=password
spring.mail.test-connection=false
###############################################

